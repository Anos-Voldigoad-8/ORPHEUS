# ═══════════════════════════════════════════════════════════
# ORPHEUS Environment Configuration Template
# Copy to .env and fill in your values: cp .env.template .env
# ⚠️ NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════

# Security — Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORPHEUS_MASTER_KEY=your_32_byte_master_key_here
AES_SALT=random_salt_for_key_derivation

# Cloud Database (e.g., Supabase)
CLOUD_DATABASE_URL=postgresql://postgres.your_supabase_id:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///database/user_activity.db

# LLM Configuration — Ollama (local AI inference)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=tinyllama
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Paths (relative to ORPHEUS root)
WORKSPACE_DIR=workspace/
LOGS_DIR=logs/
ASSETS_DIR=assets/

# Voice & Audio
WAKE_WORD=Orpheus
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
TTS_VOICE_MODEL=default

# API Keys (optional)
DUCKDUCKGO_API_KEY=
SearXNG_INSTANCE_URL=

# UI Configuration
UI_PORT=8000
UI_HOST=0.0.0.0
DASHBOARD_THEME=cyberpunk